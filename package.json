{
	"name": "minio",
	"displayName": "MinIO File Uploader",
	"description": "A VS Code Extension aimed at making upload files and images to MinIO an easy thing.",
	"version": "1.0.0",
	"publisher": "Benjamin Gross",
	"preview": false,
	"license": "MIT",
	"repository": {
		"type": "github",
		"url": "https://github.com",
		"directory": "/DrBenjamin/MinIO-VS-Code-Extension"
	},
	"engines": {
		"vscode": "^1.93.0"
	},
	"categories": [
		"Data Science"
	],
	"activationEvents": [
        "onCommand:your-extension.upload-local-disk-image",
        "onCommand:your-extension.upload-clipboard-image",
        "onCommand:your-extension.download-local-disk-image"
	],
	"main": "./out/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "minio",
					"title": "MinIO",
					"icon": "media/dep.svg"
				}
			]
		},
		"views": {
			"minio": [
				{
					"id": "ftpExplorer",
                    "title": "MinIO",
					"name": "Files",
					"icon": "media/dep.svg",
					"contextualTitle": "MinIO"
				}
			]
		},
        "menus": {
			"view/title": [
				{
					"command": "ftpExplorer.refresh",
					"when": "view == ftpExplorer",
					"group": "navigation"
				},
				{
					"command": "minio.upload-local-disk-image",
					"when": "view == ftpExplorer",
					"group": "navigation"
				}
			],
            "view/item/context": [
                {
                    "command": "minio.download-local-disk-image",
                    "when": "view == ftpExplorer",
                    "group": "inline"
                }
			],
			"editor/context": [
				{
					"command": "minio.upload-local-disk-image",
					"when": "resourceLangId == markdown",
					"group": "minio"
				},
				{
					"command": "minio.upload-clipboard-image",
					"when": "resourceLangId == markdown",
					"group": "minio"
				}
			]
		},
		"commands": [
			{
				"command": "ftpExplorer.refresh",
				"title": "Refresh",
				"icon": {
					"light": "resources/light/refresh.svg",
					"dark": "resources/dark/refresh.svg"
				}
			},
			{
				"command": "minio.upload-local-disk-image",
				"title": "Upload file from local disk to MinIO",
				"category": "minio",
                "icon": {
					"light": "resources/light/folder.svg",
					"dark": "resources/dark/folder.svg"
				}
			},
            {
				"command": "minio.download-local-disk-image",
				"title": "Download MinIO file to local disk",
				"category": "minio",
                "icon": {
					"light": "resources/light/document.svg",
					"dark": "resources/dark/document.svg"
				}
			},
			{
				"command": "minio.upload-clipboard-image",
				"title": "Upload image from clipboard to MinIO",
				"category": "minio"
			}
		],
		"configuration": [
			{
				"title": "MinIO",
				"properties": {
					"minio.minio.server.address": {
						"default": "",
						"type": "string",
						"markdownDescription": "e.g. `https://s3.amazonaws.com` `http://my-minio.xyz:5900`",
						"pattern": "(^https?://)|(^$)",
						"order": 0
					},
					"minio.minio.credential.accessKey": {
						"default": "",
						"type": "string",
						"markdownDescription": "Access key is like user ID that uniquely identifies your MinIO account.",
						"order": 1
					},
					"minio.minio.credential.secretKey": {
						"default": "",
						"type": "string",
						"markdownDescription": "Secret key is the password to your MinIO account.",
						"order": 2
					},
					"minio.minio.upload.bucketName": {
						"default": "templategenerator",
						"type": "string",
						"markdownDescription": "A bucket which files will be uploaded to",
						"order": 3
					},
					"minio.minio.upload.directory": {
						"default": "images/",
						"type": "string",
						"markdownDescription": "Subdirectory in the specific bucket to save files.\n\n  e.g. `images/`",
						"order": 4
					},
                    "minio.minio.download.directory": {
						"default": "/Users/ben/Downloads/",
						"type": "string",
						"markdownDescription": "Subdirectory in the specific bucket to save files.\n\n  e.g. `images/`",
						"order": 5
					}
				}
			}
		],
		"keybindings": [
			{
				"command": "minio.upload-local-disk-image",
				"mac": "cmd+shift+z",
				"win": "ctrl+shift+z"
			},
			{
				"command": "minio.upload-clipboard-image",
				"mac": "cmd+shift+x",
				"win": "ctrl+shift+x"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"package": "webpack --mode production --devtool hidden-source-map",
		"lint": "eslint \"src/**/*.ts\"",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@types/ftp": "^0.3.33",
		"@types/glob": "^7.1.4",
		"@types/mime-types": "^2.1.1",
		"@types/minio": "^7.0.11",
		"@types/mkdirp": "^0.5.2",
		"@types/mocha": "^9.0.0",
		"@types/node": "^20",
		"@types/rimraf": "^2.0.2",
		"@types/vscode": "^1.73.0",
		"@typescript-eslint/eslint-plugin": "^7.14.0",
		"@typescript-eslint/parser": "^7.14.0",
		"@vscode/test-electron": "^1.6.2",
		"clean-webpack-plugin": "^4.0.0",
		"copy-webpack-plugin": "^10.2.0",
		"eslint": "^8.26.0",
		"glob": "^7.1.7",
		"mocha": "^9.1.3",
		"prettier": "^2.5.1",
		"ts-loader": "^9.2.5",
		"typescript": "^4.4.4",
		"webpack": "^5.95.0",
		"webpack-cli": "^4.8.0"
	},
	"dependencies": {
		"date-fns": "^2.27.0",
		"file-loader": "^6.2.0",
		"form-data": "^4.0.0",
		"ftp": "^0.3.10",
		"is-wsl": "^2.2.0",
		"jsonc-parser": "^0.4.2",
		"mime-types": "^2.1.34",
		"minimist": "^1.2.6",
		"minio": "^7.1.3",
		"mkdirp": "^0.5.1",
		"node-fetch": "^3.0.0",
		"rimraf": "^2.6.2"
	}
}
